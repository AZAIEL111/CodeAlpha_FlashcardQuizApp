import tkinter as tk
from tkinter import simpledialog, messagebox

flashcards = [
    {"question": "What is Python?", "answer": "A programming language"},
    {"question": "What is HTML?", "answer": "A markup language"},
]

index = 0

def load_card():
    if flashcards:
        question_label.config(text=flashcards[index]["question"])
        answer_label.config(text="")
    else:
        question_label.config(text="No flashcards available")
        answer_label.config(text="")

def show_answer():
    answer_label.config(text=flashcards[index]["answer"])

def next_card():
    global index
    if flashcards:
        index = (index + 1) % len(flashcards)
        load_card()

def prev_card():
    global index
    if flashcards:
        index = (index - 1) % len(flashcards)
        load_card()

def add_card():
    question = simpledialog.askstring("Question", "Enter question:")
    answer = simpledialog.askstring("Answer", "Enter answer:")
    if question and answer:
        flashcards.append({"question": question, "answer": answer})
        messagebox.showinfo("Success", "Flashcard added!")

def delete_card():
    global index
    if flashcards:
        flashcards.pop(index)
        index = 0
        load_card()
        messagebox.showinfo("Deleted", "Flashcard deleted")

# Window
root = tk.Tk()
root.title("Flashcard Quiz App")
root.geometry("400x350")

question_label = tk.Label(root, text="", font=("Arial", 16))
question_label.pack(pady=20)

answer_label = tk.Label(root, text="", font=("Arial", 14), fg="blue")
answer_label.pack(pady=10)

btn_show = tk.Button(root, text="Show Answer", command=show_answer)
btn_show.pack(pady=5)

btn_prev = tk.Button(root, text="Previous", command=prev_card)
btn_prev.pack(side="left", padx=20, pady=20)

btn_next = tk.Button(root, text="Next", command=next_card)
btn_next.pack(side="right", padx=20, pady=20)

btn_add = tk.Button(root, text="Add Flashcard", command=add_card)
btn_add.pack(pady=5)

btn_delete = tk.Button(root, text="Delete Flashcard", command=delete_card)
btn_delete.pack(pady=5)

load_card()

root.mainloop()
